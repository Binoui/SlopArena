# ==========================================
# Unity (client/)
# ==========================================
client/Unity/[Ll]ibrary/
client/Unity/[Tt]emp/
client/Unity/[Oo]bj/
client/Unity/[Bb]uild/
client/Unity/[Bb]uilds/
client/Unity/[Ll]ogs/
client/Unity/[Uu]serSettings/
client/Unity/[Mm]emoryCapturer/
client/Unity/.vs/
client/Unity/*.csproj
client/Unity/*.uid
client/Unity/*.meta
client/Unity/*.sln
client/Unity/*.user
client/Unity/Assets/Shared/*.pdb
client/Unity/Assets/Shared/*.deps.json
client/Unity/Assets/Shared/*.meta
client/Unity/Assets/Shared/*.runtimeconfig.json

# Root Unity artifacts (orphaned)
/Library/
/Logs/
/UserSettings/
/Temp/

client/Unity/Assets/AnimationPacks
client/Unity/Assets/AnimationPacks/*
# Unity Plugins — ignore build artifacts but preserve .meta import settings
client/Unity/Assets/Plugins/**/*.dll
client/Unity/Assets/Plugins/**/*.pdb
client/Unity/Assets/Plugins/**/*.deps.json
client/Unity/Assets/Plugins/**/*.runtimeconfig.json
client/Unity/Assets/Plugins/**/NuGet/.nuget-installed.json

# Auto-generated prefabs from symlinked asset packs (regenerate on clone)
client/Unity/Assets/Prefabs/Arena_*.prefab
client/Unity/Assets/Prefabs/Arena_*.prefab.meta
client/Unity/Assets/Prefabs/Bridge_*.prefab
client/Unity/Assets/Prefabs/Bridge_*.prefab.meta

# Prevent Unity .meta file leaks into pure .NET Shared directory
src/Shared/**/*.meta

# Orphan Godot .uid metadata
*.uid.meta

# Unity crash dumps
client/Unity/mono_crash.mem.*

# Duplicate runtime data (source of truth in /data/)
client/Unity/data/


# Paid asset — do not commit
client/Unity/Packages/com.kybernetik.animancer/
.worktrees/

# Boxophobic Unity asset (external/paid, should not be tracked)
client/Unity/Assets/BOXOPHOBIC/
