#!/bin/bash
# Pre-commit hook: runs dotnet format on staged C# files
# Install: git config core.hooksPath .githooks

set -e

echo "🔍 Running dotnet format..."

# Format all C# files in the solution
dotnet format SlopArena.sln --verify-no-changes --verbosity diagnostic 2>&1 | tail -5

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Code style issues found. Run 'dotnet format SlopArena.sln' to fix."
    exit 1
fi

echo "✅ Format check passed"
